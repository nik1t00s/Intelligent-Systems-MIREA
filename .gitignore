# Системные файлы ОС
.DS_Store
Thumbs.db

# Конфигурации IDE/редакторов
.vscode/
.idea/
*.swp
*.swo

# Виртуальные окружения Python
.venv/
venv/
env/
ENV/
.conda/
.venv*/

# Кеши Python и скомпилированные файлы
__pycache__/
*.py[cod]
*$py.class

# Папки и файлы сборки/дистрибуции (если вдруг появятся)
build/
dist/
eggs/
*.egg-info/
.installed.cfg

# Кеши и артефакты тестов
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Журналы
*.log
logs/

# Кеши Jupyter Notebook
.ipynb_checkpoints

# Файлы окружения и конфигурации с потенциальными секретами
.env
*.env
.env.*
!.env.example

# Разное
*.tmp
*.bak
*.old
homeworks/HW08-09/data/ 
data/
project/data/*
!project/data/
!project/data/README.md
!project/data/demo_sample.csv
*.tar.gz
*.tar
*.zip

